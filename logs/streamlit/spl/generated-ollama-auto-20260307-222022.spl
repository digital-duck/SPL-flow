PROMPT mathematical_terms_etymology
WITH BUDGET 8000 tokens
USING MODEL "qwen2-math"

WITH cjk_analysis AS (
    PROMPT algebra_zero_terms
    WITH BUDGET 3000 tokens
    USING MODEL "qwen3"

    SELECT
        system_role("You are an expert in historical linguistics and etymology, specializing in the evolution of mathematical terms across cultures."),
        context.terms AS terms LIMIT 50 tokens

    GENERATE
        term_etymology(terms, "Analyze how concepts like 'algebra' (Arabic al-jabr), 'algorithm' (Persian al-Khwarizmi), and 'zero' (Sanskrit śūnya) traveled through languages. Create a timeline showing linguistic borrowing, semantic shifts, and cultural knowledge transfer patterns.")
    WITH OUTPUT BUDGET 1500 tokens, TEMPERATURE 0.1, FORMAT json
),

german_translations AS (
    PROMPT term_translations
    WITH BUDGET 2500 tokens
    USING MODEL "mistral"

    SELECT
        system_role("You are a professional translator specializing in historical and technical terminology."),
        context.terms AS terms LIMIT 50 tokens

    GENERATE
        translate_terms(terms, "Translate the mathematical terms 'algebra', 'algorithm', and 'zero' into German, providing their meanings in both languages.")
    WITH OUTPUT BUDGET 800 tokens, TEMPERATURE 0.1, FORMAT json
)

SELECT
    system_role("You are an expert at creating structured multilingual reference tables with historical insights."),
    context.cjk_analysis AS etymology_data LIMIT 2000 tokens,
    context.german_translations AS translations LIMIT 1500 tokens

GENERATE
    compose_table(etymology_data, translations, "Merge the mathematical term data with German translations into a markdown table with columns: | Term | Etymology | Timeline of Borrowing and Shifts | German Translation |. Match rows by term. For the Etymology column, provide detailed historical insights on the evolution of each term. For the Timeline column, include key dates and events related to linguistic borrowing and semantic shifts.")
WITH OUTPUT BUDGET 3000 tokens, TEMPERATURE 0.1, FORMAT markdown;