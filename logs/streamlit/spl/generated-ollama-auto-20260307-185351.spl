PROMPT comprehensive_api_doc_ml_library
WITH BUDGET 8000 tokens
USING MODEL "qwen3"

SELECT
    system_role("You are a technical writer specializing in generating comprehensive API documentation, focusing on clarity, usability, and code examples."),
    context.library_name AS library_name LIMIT 250 tokens

GENERATE
    generate_doc("Create comprehensive API documentation for the {library_name} machine learning library. Include installation guides, authentication setup, rate limiting considerations, error handling patterns, and performance optimization tips. Provide examples in Python. Format as interactive documentation with code snippets and expected outputs.")
WITH OUTPUT BUDGET 4000 tokens, TEMPERATURE 0.2, FORMAT markdown;